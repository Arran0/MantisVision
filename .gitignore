# --- Node / Next.js (apps/web) ---
node_modules/
.next/
out/
.env
.env.local
.env.*.local
npm-debug.log*
.vercel
*.tsbuildinfo

# --- Python / ML (ml) ---
.venv/
venv/
__pycache__/
*.pyc
ml/checkpoints/*
!ml/checkpoints/.gitkeep
ml/logs/
ml/reports/

# Dataset images live on Kaggle (see ml/scripts/kaggle_sync.py), not git —
# keep the folder structure (.gitkeep files) but ignore actual photos.
# Dataset dirs are species-scoped (ml/dataset/<species_slug>/...); the `*` in
# place of the slug means a future second species folder is auto-ignored
# without another edit here.
ml/dataset/*/train/*/*
ml/dataset/*/validation/*/*
ml/dataset/*/test/*/*
!ml/dataset/**/.gitkeep
# dataset-metadata.json itself (not the .example) is intentionally NOT
# ignored — it's just the Kaggle dataset id/title, not a secret, and every
# contributor needs the same one to push to the same Kaggle dataset.

# Kaggle API credentials must never be committed
kaggle.json
.kaggle/

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
