# URL of the Python FastAPI inference service (ml/src/api/main.py)
ML_API_URL=http://localhost:8000

# Supabase (admin auth, dataset labeling, and Milestone 7 — storing uploaded
# photos + prediction history). Apply migrations in supabase/migrations/.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub Actions dispatch for the admin "Retrain model" button
# (.github/workflows/retrain.yml). Fine-grained PAT needs actions:write +
# contents:write on this repo.
GITHUB_TOKEN=
GITHUB_REPO=owner/mantisvision
