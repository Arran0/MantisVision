# URL of the Python FastAPI inference service (ml/src/api/main.py)
ML_API_URL=http://localhost:8000

# Shared secret for hot-swapping the live model on promotion. Must match
# RELOAD_TOKEN set on the ML API host (Render/Hugging Face Space). Clicking
# "Promote" POSTs to {ML_API_URL}/admin/reload with this as a bearer token.
ML_API_ADMIN_TOKEN=

# Supabase (admin auth, dataset labeling, and Milestone 7 — storing uploaded
# photos + prediction history). Apply migrations in supabase/migrations/.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the web app (e.g. https://mantisvision.vercel.app). Used
# to build the invite/password-reset link teammates receive. Falls back to the
# request origin if unset, which is fine for local dev but should be set in
# production so links point at the real domain.
NEXT_PUBLIC_SITE_URL=

# GitHub Actions dispatch for the admin "Retrain model" button
# (.github/workflows/retrain.yml). Fine-grained PAT needs actions:write +
# contents:write on this repo.
GITHUB_TOKEN=
GITHUB_REPO=owner/mantisvision
