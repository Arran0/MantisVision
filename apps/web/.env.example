# URL of the Python FastAPI inference service (ml/src/api/main.py)
ML_API_URL=http://localhost:8000

# Supabase (admin auth + retrain-run tracking, and Milestone 7 — storing
# prediction history). Apply migrations in supabase/migrations/. The dataset
# itself (admin-labeled training photos) does NOT live here — see the
# GITHUB_TOKEN/GITHUB_REPO block below.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used for two things: (1) dispatching the admin "Retrain model" button
# (.github/workflows/retrain.yml), and (2) staging admin-uploaded dataset
# photos on the dataset-staging git branch (apps/web/src/lib/github.ts) —
# Kaggle is the durable dataset store, but its API only supports syncing a
# whole folder as a new version, not real-time single-file inserts from a web
# request, so uploads land here first and get batched into Kaggle during the
# next retrain run. Fine-grained PAT needs actions:write + contents:write on
# this repo.
GITHUB_TOKEN=
GITHUB_REPO=owner/mantisvision
